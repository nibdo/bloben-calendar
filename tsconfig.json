{
  "compilerOptions": {
    "target": "es5",
    "baseUrl": "src",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react"
  },
  "include": [
    "src"
  ],
  "paths": {
    "bloben-common": ["./bloben-common"],
    "bloben-package": ["./bloben-package"],
    "bloben-components": ["./bloben-components"],
    "bloben-utils": ["./bloben-utils"],
    "components": ["./components"],
    "entities": ["./data/entities/"],
    "utils": ["./utils"]
  }
}
